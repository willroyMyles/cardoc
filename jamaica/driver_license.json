[
  {
    "type": "drivers_licence",
    "label": "Driver's Licence",
    "issuing_authority": "Tax Administration Jamaica (TAJ) / Island Traffic Authority (ITA)",
    "fields": {
      "fullName": { "label": "Full Name", "type": "string", "required": true },
      "licenseNumber": { "label": "Licence Number", "type": "string", "pattern": "^\\d{7}$", "required": true },
      "dateOfBirth": { "label": "Date of Birth", "type": "date", "format": "ISO 8601", "required": true },
      "issueDate": { "label": "Issue Date", "type": "date", "format": "ISO 8601", "required": true },
      "expiryDate": { "label": "Expiry Date", "type": "date", "format": "ISO 8601", "required": true },
      "licenseClass": { "label": "Licence Class", "type": "string", "required": true },
      "address": { "label": "Address", "type": "string", "required": true },
      "trn": { "label": "Tax Registration Number", "type": "string", "pattern": "^\\d{9}$", "required": true },
      "collectorate": { "label": "Collectorate", "type": "string", "required": false },
      "sex": { "label": "Sex", "type": "enum", "values": ["M", "F"], "required": true },
      "nationality": { "label": "Nationality", "type": "string", "required": false },
      "originalIssueDate": { "label": "Original Issue Date", "type": "date", "format": "ISO 8601", "required": false },
      "date": { "label": "Date", "type": "date", "format": "ISO 8601", "required": false },
      "licenseToDrive": { "label": "Licence to Drive", "type": "string", "required": false },
      "controlNumber": { "label": "Control Number", "type": "string", "required": false },
      "judicialEndorsement": { "label": "Judicial Endorsement", "type": "string", "required": false }
    }
  }
]
